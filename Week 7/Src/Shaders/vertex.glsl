#version 330 core

//--------------------------------------------------
// Vertex Attributes
//--------------------------------------------------

layout(location = 0)
in vec3 aPos;

layout(location = 1)
in vec3 aColor;

//--------------------------------------------------
// Outputs
//--------------------------------------------------

out vec3 vertexColor;

//--------------------------------------------------
// Uniforms
//--------------------------------------------------

uniform mat4 mvp;

//--------------------------------------------------
// Main
//--------------------------------------------------

void main()
{
    gl_Position =
        mvp *
        vec4(
            aPos,
            1.0);

    vertexColor =
        aColor;
}